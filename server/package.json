{
  "name": "@amalgam/server",
  "version": "0.1.0",
  "description": "API service for amalgam",
  "author": "Uday Tiwari",
  "license": "BSD-3-Clause",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "start": "node dist/app.js",
    "dev": "tsx watch app.ts",
    "seed": "npx prisma db seed",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@amalgam/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.3.0",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.18.0",
    "globals": "^17.5.0",
    "prisma": "^7.5.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.58.2"
  }
}
