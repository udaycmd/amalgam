{
  "name": "amalgam",
  "version": "0.1.0",
  "author": "Uday Tiwari",
  "private": true,
  "license": "BSD-3-Clause",
  "scripts": {
    "dev:server": "pnpm --filter \"@amalgam/server\" dev",
    "dev:web": "pnpm --filter \"@amalgam/web\" dev",
    "dev": "pnpm build:shared && pnpm --parallel dev",
    "build:server": "pnpm --filter \"@amalgam/server\" build",
    "build:web": "pnpm --filter \"@amalgam/web\" build",
    "build:shared": "pnpm --filter \"@amalgam/shared\" build",
    "build": "pnpm --recursive build",
    "format:server": "pnpm --filter \"@amalgam/server\" format",
    "format:web": "pnpm --filter \"@amalgam/web\" format",
    "format:shared": "pnpm --filter \"@amalgam/shared\" format",
    "format": "pnpm --parallel format",
    "typecheck:server": "pnpm --filter \"@amalgam/server\" typecheck",
    "typecheck:web": "pnpm --filter \"@amalgam/web\" typecheck",
    "typecheck:shared": "pnpm --filter \"@amalgam/shared\" typecheck",
    "typecheck": "pnpm --parallel typecheck",
    "lint:server": "pnpm --filter \"@amalgam/server\" lint",
    "lint:web": "pnpm --filter \"@amalgam/web\" lint",
    "lint": "pnpm --parallel lint"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver",
      "msw"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
